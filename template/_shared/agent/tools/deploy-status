#!/usr/bin/env python3
"""Show the recent nuklaut deploy runs and where this app is published.

Read-only wrapper over `gh run list` (needs `gh` authenticated; no SSH). Self-contained:
stdlib only, bare python3, works in Python and Node apps alike.

Usage: agent/tools/deploy-status [--limit N] [--json]
"""

from __future__ import annotations

import argparse
import json
import subprocess
import sys
from pathlib import Path


def repo_name() -> str:
    try:
        proc = subprocess.run(
            ["git", "remote", "get-url", "origin"], capture_output=True, text=True, timeout=5, check=False
        )
        url = proc.stdout.strip()
        if proc.returncode == 0 and url:
            return Path(url.rstrip("/")).name.removesuffix(".git")
    except (OSError, subprocess.TimeoutExpired):
        pass
    return Path.cwd().resolve().name


def fetch_runs(limit: int) -> list[dict]:
    proc = subprocess.run(
        [
            "gh", "run", "list", "--workflow", "deploy.yml", "--limit", str(limit),
            "--json", "databaseId,status,conclusion,displayTitle,headSha,updatedAt,url",
        ],
        capture_output=True,
        text=True,
        timeout=30,
        check=False,
    )
    if proc.returncode != 0:
        sys.stderr.write(proc.stderr or "gh failed — is `gh` installed and authenticated?\n")
        raise SystemExit(2)
    return json.loads(proc.stdout or "[]")


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description=__doc__.splitlines()[0])
    parser.add_argument("--limit", type=int, default=5, help="how many runs to show (default 5)")
    parser.add_argument("--json", action="store_true", help="emit JSON")
    args = parser.parse_args(argv)

    name = repo_name()
    runs = fetch_runs(args.limit)
    info = {
        "repo": name,
        "app_url": f"https://{name}.astrojones.de",
        "image": f"ghcr.io/astrojones/{name}:latest",
        "runs": runs,
    }
    if args.json:
        print(json.dumps(info, indent=2))
        return 0
    print(f"app:   https://{name}.astrojones.de   (health: curl -fsS https://{name}.astrojones.de/health)")
    print(f"image: ghcr.io/astrojones/{name}:latest")
    if not runs:
        print("runs:  none found — has main been pushed yet?")
    for run in runs:
        state = run["conclusion"] or run["status"]
        print(f"  [{state:<9}] {run['updatedAt']}  {run['headSha'][:7]}  {run['displayTitle']}  {run['url']}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
