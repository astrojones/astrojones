#!/usr/bin/env python3
"""Print the logs of the latest (or a given) nuklaut deploy run — failed steps first.

Read-only wrapper over `gh run view` (needs `gh` authenticated; no SSH). Self-contained:
stdlib only, bare python3, works in Python and Node apps alike.

Usage: agent/tools/deploy-logs [--run ID] [--full]
"""

from __future__ import annotations

import argparse
import json
import subprocess
import sys


def _gh(args: list[str], timeout: int = 60) -> subprocess.CompletedProcess:
    proc = subprocess.run(["gh", *args], capture_output=True, text=True, timeout=timeout, check=False)
    if proc.returncode != 0:
        sys.stderr.write(proc.stderr or "gh failed — is `gh` installed and authenticated?\n")
        raise SystemExit(2)
    return proc


def latest_run() -> dict | None:
    proc = _gh(["run", "list", "--workflow", "deploy.yml", "--limit", "1",
                "--json", "databaseId,status,conclusion,displayTitle,url"])
    runs = json.loads(proc.stdout or "[]")
    return runs[0] if runs else None


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description=__doc__.splitlines()[0])
    parser.add_argument("--run", default=None, help="run id (default: latest deploy run)")
    parser.add_argument("--full", action="store_true", help="full log instead of failed steps only")
    args = parser.parse_args(argv)

    run_id, conclusion = args.run, None
    if run_id is None:
        run = latest_run()
        if run is None:
            print("no deploy runs found — has main been pushed yet?")
            return 1
        run_id, conclusion = str(run["databaseId"]), run["conclusion"]
        print(f"run {run_id} [{conclusion or run['status']}] {run['displayTitle']}  {run['url']}\n")

    if conclusion == "success" and not args.full:
        print("latest deploy succeeded — use --full for the complete log,")
        print("or check the app: agent/tools/deploy-status")
        return 0

    log_flag = "--log" if args.full else "--log-failed"
    proc = _gh(["run", "view", run_id, log_flag], timeout=120)
    sys.stdout.write(proc.stdout)
    return 0


if __name__ == "__main__":
    sys.exit(main())
